# Desktop QuartoReview configuration
#
# Use either:
# 1. GITHUB_TOKEN for a single-user local install, or
# 2. GITHUB_CLIENT_ID + GITHUB_CLIENT_SECRET + REDIRECT_URI for GitHub OAuth.

SESSION_SECRET=replace-this-with-a-long-random-secret

# Simplest option for a personal desktop install:
# GITHUB_TOKEN=ghp_replace_this_with_a_repo_scoped_token

# OAuth option:
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# REDIRECT_URI=http://localhost:3001/api/auth/callback
