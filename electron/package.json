{
  "name": "quartoreview",
  "version": "0.0.11",
  "description": "Electron wrapper for QuartoReview",
  "license": "MIT",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build": "electron-builder"
  },
  "build": {
    "appId": "nl.tue.quartoreview",
    "productName": "QuartoReview",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "splash.html",
      "setup.html",
      "setup-preload.cjs",
      "icon.png",
      "package.json"
    ],
    "icon": "icon.ico",
    "extraResources": [
      {
        "from": "../GUIDE.md",
        "to": "guide/GUIDE.md"
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!.env",
          "!sessions/**",
          "!node_modules/.cache/**"
        ]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1"
  }
}
